DATABASE_URL="postgresql://username:password@localhost:5432/captheflag"
JWT_SECRET="change-me-random-64-chars"
PORT=3001
NODE_ENV=development
# Public subdomains the portal links out to (full stats sites per game)
BF1942_API_URL="https://bf1942.captheflag.com"
BFV_API_URL="https://bfv.captheflag.com"

# Internal stats-engine base URLs (FastAPI). These run on the SAME box as the
# portal, so talk to them over localhost — do NOT expose them publicly.
# Defaults if unset: BF1942 -> http://127.0.0.1:8000, BFV -> http://127.0.0.1:8001
BF1942_STATS_URL="http://127.0.0.1:8000"
BFV_STATS_URL="http://127.0.0.1:8001"

NEXT_PUBLIC_DISCORD_URL="https://discord.gg/yourserver"
NEXT_PUBLIC_SITE_URL="https://captheflag.com"
